# direnv config — activates venv and loads .env when you cd into this dir
# Run: direnv allow

# Create venv if not exists (Python 3.12 recommended)
if [[ ! -d .venv ]]; then
    echo "Creating venv... (run 'python3.12 -m venv .venv' manually if this fails)"
    python3.12 -m venv .venv || python3 -m venv .venv
fi

# Activate
source .venv/bin/activate

# Load env vars
dotenv_if_exists .env

# Add src to PYTHONPATH so `from pharma_intel import ...` works
export PYTHONPATH="$PWD/src:$PYTHONPATH"
