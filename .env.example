# ============================================================================
# LLM Provider Selection
# ============================================================================
# Supported values:
#   thaillm    — Sovereign Thai LLM (OpenThaiGPT) via thaillm.or.th [DEFAULT]
#   anthropic  — Anthropic Claude (for research benchmarking)
LLM_PROVIDER=thaillm

# ============================================================================
# ThaiLLM (OpenThaiGPT) — PRIMARY PROVIDER
# ============================================================================
# Request access at: http://thaillm.or.th
# Rate limits: 5 req/sec, 200 req/min
# ⚠️ Endpoint uses HTTP (not HTTPS) — do not use on untrusted networks
THAILLM_API_KEY=
THAILLM_BASE_URL=http://thaillm.or.th/api/v1
THAILLM_MODEL=openthaigpt-thaillm-8b-instruct-v7.2

# ============================================================================
# Anthropic Claude — OPTIONAL (for benchmarking in paper)
# ============================================================================
# Get from: https://console.anthropic.com/
# Only required if LLM_PROVIDER=anthropic, or when running benchmark scripts
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# For bulk/cheap: claude-haiku-4-5-20251001
# For complex reasoning: claude-opus-4-7

# ============================================================================
# Paths (override to use external drive / Google Drive)
# ============================================================================
DATA_DIR=./data
CHROMA_PERSIST_DIR=./chroma_db
MODEL_CACHE_DIR=./.cache/models

# ============================================================================
# Embedding model (bilingual Thai+English SOTA)
# ============================================================================
EMBEDDING_MODEL=BAAI/bge-m3
# For fast local dev (smaller, lower quality):
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
